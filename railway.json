{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJsonPath": "railway.json",
    "buildCommand": "npm install && npx prisma migrate deploy && npm start",
    "watchPatterns": ["server/**"]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": [
    {
      "name": "backend",
      "path": "server",
      "port": 3000,
      "healthCheckPath": "/health"
    }
  ]
}
